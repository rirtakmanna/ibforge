rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─────────────────────────────────────────────────────────────
    // deliverables/{userId}/{stepId}/{fileName}
    // IB training deliverable uploads. Owner-only read/write.
    // 10MB cap. Allowed types: Excel, PDF, Office docs, images.
    // ─────────────────────────────────────────────────────────────
    match /deliverables/{userId}/{stepId}/{fileName} {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow write:  if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches(
                         'application/vnd.openxmlformats-officedocument.*|'
                         + 'application/vnd.ms-excel|'
                         + 'application/pdf|'
                         + 'image/(png|jpeg|webp)'
                       );
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ─────────────────────────────────────────────────────────────
    // submissions/{userId}/{submissionId}/{fileName}
    // UPI payment screenshot uploads.
    // Path encodes the uploader's UID so Storage rules can verify
    // ownership without a Firestore cross-reference.
    // Owner read/write. Admin read/delete. 5MB cap. Images only.
    // ─────────────────────────────────────────────────────────────
    match /submissions/{userId}/{submissionId}/{fileName} {
      allow read:   if request.auth != null
                    && (request.auth.uid == userId
                        || request.auth.uid == "EkrdYX5YxEe23ObfGno7m8duqEx2");
      allow write:  if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
                    && (request.auth.uid == userId
                        || request.auth.uid == "EkrdYX5YxEe23ObfGno7m8duqEx2");
    }
  }
}