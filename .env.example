VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
GEMINI_API_KEY=your_gemini_api_key
VITE_ADMIN_UID=
# Server-side only — never prefix with VITE_ (would expose key in client bundle).

# ─────────────────────────────────────────────────────────────────────
# Firebase Cloud Function — set via Firebase CLI, NOT in .env files:
#   firebase functions:secrets:set FB_TOOLS_TOKEN
# Get the token by running `firebase login:ci` once and copying the
# output. This token is used by the deleteAccount function only.
# ─────────────────────────────────────────────────────────────────────