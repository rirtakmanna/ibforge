rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // access-codes/{code}
    // Trial and full access codes. Read/write denied to all clients —
    // only Cloud Functions (claimCode, issueTrialCode) touch this
    // collection via the Admin SDK, which bypasses these rules.
    // ─────────────────────────────────────────────────────────────
    match /access-codes/{code} {
      allow read: if false;
      allow write: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // trial-requests/{email}
    // Rate-limit doc keyed by email. issueTrialCode Cloud Function
    // writes lastRequestedAt; no client ever reads or writes this.
    // ─────────────────────────────────────────────────────────────
    match /trial-requests/{email} {
      allow read: if false;
      allow write: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // users/{userId} — the user document itself.
    //
    // Reads: owner only.
    //
    // Writes: owner only, AND the write must NEVER touch the three
    // server-controlled fields: access, role, codeUsed. Cloud Functions
    // using the Admin SDK bypass these rules and remain the only way
    // those fields are ever written.
    //
    // The client IS allowed to write onboardingComplete and any other
    // app-state fields the operator's UI needs to set.
    // ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      // Returns true if the incoming write payload contains ANY of the
      // three server-controlled keys. We use the keys() of request.resource.data
      // intersected with the protected set — if the intersection is non-empty,
      // the client is trying to touch a forbidden field.
      function touchesServerFields() {
        // request.writeFields contains ONLY the keys being written in this
        // operation — not the full merged document. This is the correct check
        // for merge writes, where request.resource.data includes pre-existing
        // fields the client never named.
        return request.writeFields.hasAny(['access', 'role', 'codeUsed']);
      }

      allow read: if isOwner();

      // Create: owner only, must not include any server-controlled field.
      allow create: if isOwner()
                    && request.resource.data.size() < 1000000
                    && !touchesServerFields();

      // Update: owner only, must not include any server-controlled field
      // in the incoming write payload. This is stricter than "field must
      // not change" — it forbids the field from being present in the write
      // at all. (Setting a field to its existing value still counts as
      // a write to that field in Firestore Rules' eyes, so this is the
      // correct stance for fields the client should never name.)
      allow update: if isOwner()
                    && request.resource.data.size() < 1000000
                    && !touchesServerFields();

      // Delete: owner only.
      allow delete: if isOwner();
    }

    // ─────────────────────────────────────────────────────────────
    // users/{userId}/{collection}/{document=**} — all subcollections
    // under the user document (progress, deliverables, uiState,
    // schedule, etc).
    //
    // The {collection} segment is required so this rule matches
    // ONLY subcollection documents, never the user document itself.
    // Without it, the recursive wildcard {document=**} matches the
    // user document too, and Firestore Rules OR-unions all matching
    // rule allows — which would silently bypass the strict field-level
    // protections in the rule above.
    //
    // Owner-only. Writes also enforce the trial plan boundary:
    // trial users may only write to subcollections for steps in
    // Module 1 (phase 1). The step's phase is encoded in the first
    // segment of the document path — progress and scheduledPosts use
    // a single doc ("completedSteps" and a post id respectively), so
    // we gate by collection name instead. Deliverables use the stepId
    // as the document id (e.g. "M1-S09") — we extract the module
    // number from it to enforce the boundary.
    //
    // Plan check: reads users/{uid}.access.plan via get(). This costs
    // one extra read per subcollection write — acceptable for the
    // security guarantee. Cloud Functions bypass via Admin SDK.
    // ─────────────────────────────────────────────────────────────
    match /users/{userId}/{collection}/{document=**} {
      function getUserPlan() {
        let userDoc = get(/databases/$(database)/documents/users/$(userId));
        return userDoc != null
               && userDoc.data != null
               && userDoc.data.access != null
                 ? userDoc.data.access.plan
                 : null;
      }

      // Returns true if the write is permitted under the user's plan.
      // "full" → always allowed.
      // null   → no access record yet → deny writes (claimCode hasn't
      //          run yet, or the record was deleted).
      // "trial" → allowed only for:
      //   - progress subcollection (single doc — completedSteps)
      //     gated further by the stepId inside the payload; but Rules
      //     cannot inspect array contents cheaply, so we allow the
      //     collection and rely on the client-side assertPlanAllowsStep
      //     guard + the deliverables doc-id check below for granularity.
      //   - deliverables subcollection: document id is the stepId.
      //     M1 steps have ids starting with "M1-". Any other prefix
      //     (M2-, M3-, …) is denied for trial users.
      //   - scheduledPosts subcollection: post ids are
      //     "{stepId}-day{N}-{index}". Extract the step prefix.
      //   - all other subcollections (uiState, meta): always allowed
      //     regardless of plan — they contain no gated content.
      function planAllowsWrite() {
        let plan = getUserPlan();
        // "full" → always allowed.
        // null   → no access record → deny.
        // "trial" → deliverables and scheduledPosts gated to M1- prefix;
        //           all other subcollections (progress, uiState, meta) allowed.
        return plan == "full"
          ? true
          : plan == null
            ? false
            : (collection == "deliverables" || collection == "scheduledPosts")
              ? document.matches("M1-.*")
              : true;
      }

      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.size() < 1000000
                   && planAllowsWrite();
    }
  }
}